<Window x:Class="WoWAddonIDE.Windows.MultiTocWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Flavor TOC Files" Height="420" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.BackgroundBrush}"
        Foreground="{DynamicResource App.ForegroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Generate flavor-specific TOC files for your addon. Each checked flavor will create an AddonName_Flavor.toc with the specified Interface version. The base TOC is used as a template."/>

        <TextBlock Grid.Row="1" Margin="0,0,0,6" FontWeight="SemiBold">
            <Run Text="Base TOC: "/>
            <Run x:Name="BaseTocLabel" Text="(none)"/>
        </TextBlock>

        <DataGrid x:Name="FlavorGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Generate" Binding="{Binding IsChecked}" Width="80"/>
                <DataGridTextColumn Header="Flavor" Binding="{Binding DisplayName}" IsReadOnly="True" Width="180"/>
                <DataGridTextColumn Header="Interface Version" Binding="{Binding InterfaceVersion}" Width="130"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="ExistingLabel" Grid.Row="3" Margin="0,0,0,8" TextWrapping="Wrap"
                   Foreground="Gray" FontStyle="Italic"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Generate" Width="120" Margin="0,0,8,0" IsDefault="True" Click="Generate_Click"/>
            <Button Content="Close" Width="100" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
