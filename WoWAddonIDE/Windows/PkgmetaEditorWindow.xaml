<Window x:Class="WoWAddonIDE.Windows.PkgmetaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=".pkgmeta Editor" Height="600" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.BackgroundBrush}"
        Foreground="{DynamicResource App.ForegroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Configure .pkgmeta for CurseForge/Wago BigWigs packager. This file controls how your addon is packaged for distribution."/>

        <!-- Package name -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Package As:" VerticalAlignment="Center"/>
            <TextBox x:Name="PackageAsBox" Grid.Column="1"/>
        </Grid>

        <!-- Options -->
        <CheckBox x:Name="NoLibCheck" Grid.Row="2" Content="Enable nolib creation (creates a -nolib zip without embedded libs)"
                  IsChecked="True" Margin="0,0,0,8"/>

        <!-- Libraries -->
        <GroupBox Grid.Row="3" Header="External Libraries" Margin="0,0,0,8" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="LibraryCheckboxes"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Keyword tokens reference -->
        <GroupBox Grid.Row="4" Header="Keyword Tokens (use in your Lua/TOC files)">
            <ListView x:Name="KeywordList" BorderThickness="0"
                      Background="{DynamicResource App.BackgroundBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Token" Width="230" DisplayMemberBinding="{Binding Token}"/>
                        <GridViewColumn Header="Description" Width="380" DisplayMemberBinding="{Binding Description}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Preview -->
        <TextBlock x:Name="PreviewLabel" Grid.Row="5" Margin="0,8,0,4" FontStyle="Italic" Foreground="Gray"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Generate .pkgmeta" Width="140" Margin="0,0,8,0" IsDefault="True" Click="Generate_Click"/>
            <Button Content="Close" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
