<Window x:Class="WoWAddonIDE.Windows.ApiDocsBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WoW API Browser"
        Width="960" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource App.BackgroundBrush}"
        Foreground="{DynamicResource App.ForegroundBrush}"
        KeyDown="Window_KeyDown">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Border Grid.Row="0" Margin="12,12,12,6"
                BorderBrush="{DynamicResource App.BorderBrush}"
                BorderThickness="1" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <Grid Grid.Column="1">
                    <TextBox x:Name="SearchBox"
                             Height="28" Padding="6,2"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock Text="Type to search APIs by name, signature, or description..."
                               Margin="10,0,6,0" VerticalAlignment="Center"
                               IsHitTestVisible="False" Opacity="0.55">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Grid.Column="2" x:Name="CountText"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Opacity="0.7"/>
            </Grid>
        </Border>

        <!-- Main content: Category tree + Detail -->
        <Grid Grid.Row="1" Margin="12,0,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Category tree -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource App.BorderBrush}"
                    BorderThickness="1">
                <TreeView x:Name="ApiTree"
                          SelectedItemChanged="ApiTree_SelectedItemChanged"
                          Background="{DynamicResource App.BackgroundBrush}"
                          Foreground="{DynamicResource App.ForegroundBrush}"/>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource App.BorderBrush}"/>

            <!-- Detail panel -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource App.BorderBrush}"
                    BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="DetailName"
                                   FontSize="18" FontWeight="Bold"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock x:Name="DetailCategory"
                                   FontSize="12" Opacity="0.7"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Signature" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Border Background="{DynamicResource App.BackgroundBrush}"
                                BorderBrush="{DynamicResource App.BorderBrush}"
                                BorderThickness="1" Padding="8" Margin="0,0,0,12">
                            <TextBox x:Name="DetailSignature"
                                     FontFamily="Consolas" FontSize="14"
                                     IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource App.ForegroundBrush}"
                                     TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DetailDescription"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   FontSize="13"/>

                        <TextBlock Text="Category" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DetailCategoryFull"
                                   TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" LastChildFill="False" Margin="12,0,12,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Margin="0,0,12,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Copy Name" Width="100" Click="CopyName_Click" Margin="0,0,8,0"/>
                <Button Content="Copy Signature" Width="110" Click="CopySignature_Click" Margin="0,0,8,0"/>
                <Button Content="Insert at Cursor" Width="110" Click="InsertAtCursor_Click" Margin="0,0,8,0"/>
                <Button Content="Close" Width="80" Click="Close_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
